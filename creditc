:root {
  --primary-color: #7a4f3e;
  --accent-color: #ffa726;
  --secondary-color: #88024f;
  --admin-color: #4b145e;
}

/* ===== Overlay ===== */
.modal-overlay {
  position: fixed;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* ===== Modal Card ===== */
.modal-card {
  position: relative;
  background-color: #ffffff;
  width: 400px;
  padding: 2.4rem;
  border-radius: 16px;
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
  text-align: center;
  animation: slideUp 0.4s ease forwards;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===== Close Button ===== */
.close-btn {
  position: absolute;
  top: 12px;
  right: 14px;
  background: transparent;
  border: none;
  color: #999;
  font-size: 1.6rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  line-height: 1;
  z-index: 10;
}

.close-btn:hover {
  color: var(--accent-color);
  transform: scale(1.2);
}

/* ===== Modal Title ===== */
.modal-card h2 {
  color: var(--primary-color);
  font-size: 1.5rem;
  margin-bottom: 1.5rem;
}

/* ===== Inputs and Select ===== */
.modal-card input,
.modal-card select {
  width: 100%;
  padding: 10px 12px;
  margin-bottom: 1rem;
  border: 1px solid #ccc;
  border-radius: 6px;
  font-size: 1rem;
  outline: none;
  transition: border-color 0.3s;
}

.modal-card input:focus,
.modal-card select:focus {
  border-color: var(--accent-color);
  box-shadow: 0 0 5px rgba(255, 167, 38, 0.5);
}

/* ===== Buttons ===== */
.modal-card button {
  width: 100%;
  padding: 12px;
  border-radius: 6px;
  color: white;
  font-size: 1rem;
  border: none;
  cursor: pointer;
  transition: transform 0.3s, background-color 0.3s;
  background-color: var(--primary-color);
}

.modal-card button:hover {
  background-color: var(--accent-color);
  transform: scale(1.05);
}

/* ===== Error Box ===== */
.error-box {
  color: var(--secondary-color);
  background-color: rgba(255, 0, 0, 0.05);
  border-left: 3px solid var(--secondary-color);
  padding: 8px 10px;
  margin-bottom: 1rem;
  border-radius: 4px;
  font-size: 0.9rem;
}

/* ===== Responsive Modal ===== */
@media (max-width: 500px) {
  .modal-card {
    width: 90%;
    padding: 2rem;
  }
}

