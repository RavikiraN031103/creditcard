:root {
  --primary-color: #7a4f3e;
  --accent-color: #ffa726;
  --text-color: #333333;
}

/* Overlay */
.modal-overlay {
  position: fixed;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.3s ease-in-out;
}

/* Card */
.modal-card {
  background-color: #fff;
  padding: 2rem;
  border-radius: 14px;
  box-shadow: 0 6px 24px rgba(0, 0, 0, 0.25);
  width: 380px;
  text-align: center;
  position: relative;
  animation: popup 0.3s ease;
}

.modal-card h2 {
  color: var(--primary-color);
  margin-bottom: 1.2rem;
  font-weight: 600;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes popup {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

/* Button in modal */
.modal-card button {
  width: 100%;
  padding: 12px;
  border-radius: 6px;
  background-color: var(--primary-color);
  color: white;
  font-size: 1rem;
  border: none;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.modal-card button:hover {
  background-color: var(--accent-color);
}

@media (max-width: 500px) {
  .modal-card {
    width: 90%;
    padding: 1.8rem;
  }
}

