:root {
  --primary-color: #7a4f3e;
  --accent-color: #ffa726;
  --secondary-color: #88024f;
  --admin-color: #4b145e;
  --text-color: #333333;
}

/* ===== Animated Background ===== */
.login-landing {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  font-family: "Poppins", sans-serif;
  color: #fff;
  text-align: center;
  overflow: hidden;
}

.login-landing::before {
  content: "";
  position: absolute;
  inset: 0;
  background: url("../assets/simba-bg.jpg") center/cover no-repeat;
  transform: scale(1);
  animation: bgZoom 20s ease-in-out infinite alternate;
  z-index: 0;
}

.login-landing::after {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 1;
}

@keyframes bgZoom {
  0% {
    transform: scale(1);
  }
  100% {
    transform: scale(1.1);
  }
}

/* ===== Welcome Box ===== */
.welcome-box {
  position: relative;
  z-index: 2;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.25);
  padding: 3rem 3.5rem;
  border-radius: 20px;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
  text-align: center;
  max-width: 450px;
  transition: transform 0.4s ease, box-shadow 0.4s ease;
}

.welcome-box:hover {
  transform: translateY(-8px);
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
}

/* ===== Headings ===== */
.login-landing h1 {
  font-size: 2.6rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: 0.6rem;
}

.login-landing h1 span {
  color: var(--accent-color);
}

.login-landing p {
  font-size: 1.1rem;
  color: #f8f8f8;
  margin-bottom: 2.5rem;
  opacity: 0.95;
  max-width: 500px;
}

/* ===== Buttons ===== */
.landing-buttons {
  display: flex;
  justify-content: center;
  gap: 1rem;
  width: 100%;
}

.btn {
  padding: 12px 26px;
  border: none;
  border-radius: 10px;
  font-size: 1rem;
  cursor: pointer;
  font-weight: 500;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.btn::after {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.4);
  transform: skewX(-20deg);
  transition: left 0.5s ease;
}

.btn:hover::after {
  left: 120%;
}

/* Login and Signup Buttons */
.btn-user {
  background: var(--primary-color);
  color: #fff;
}
.btn-user:hover {
  background: var(--accent-color);
  transform: scale(1.05);
}

.btn-admin {
  background: var(--admin-color);
  color: #fff;
}
.btn-admin:hover {
  background: var(--accent-color);
  transform: scale(1.05);
}

/* ===== Responsive ===== */
@media (max-width: 600px) {
  .welcome-box {
    width: 90%;
    padding: 2.2rem 2rem;
  }

  .landing-buttons {
    flex-direction: column;
  }

  .login-landing h1 {
    font-size: 2rem;
  }
}
