package com.sc.cib.trade.process.alert;

import com.sc.cib.message.model.BusinessEvent;
import com.sc.cib.message.model.MessageProcessor;
import com.sc.cib.message.model.MessageStatus;
import com.sc.cib.message.model.MessageWrapper;
import com.sc.cib.message.util.JsonConverter;
import com.sc.cib.common.data.Constants;

import lombok.extern.slf4j.Slf4j;

import org.apache.commons.lang3.StringUtils;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.util.List;
import java.util.Map;

@Slf4j
@Service("sendToBankAlertProcessor")
public class SendToBankAlertProcessor implements MessageProcessor {

    @Autowired
    private AlertEmailMapper alertEmailMapper;

    @Override
    public MessageStatus process(MessageWrapper messageWrapper) {

        log.info("SendToBankAlertProcessor - Processing started");

        try {
            // 🔹 Step 1: Convert message
            BusinessEvent businessEvent = JsonConverter.fromJson(
                    messageWrapper.getMessage(),
                    BusinessEvent.class
            );

            log.info("BusinessEvent: {}", businessEvent);

            // 🔥 Step 2: Extract recId
            Long recId = extractRecId(businessEvent);

            // 🔴 Step 3: Validation
            if (recId == null) {
                log.error("recId is missing in message");

                return MessageStatus.of(
                        MessageWrapper.Status.FAILED,
                        "recId is missing"
                );
            }

            log.info("Processing for recId: {}", recId);

            // 🔥 Step 4: Fetch emails using mapper (LIKE FileSubmissionProcessor)
            List<String> emailList = alertEmailMapper.getEmailIds(recId);

            // 🔴 Step 5: Handle no emails
            if (emailList == null || emailList.isEmpty()) {
                log.info("No email IDs found for recId: {}", recId);

                return MessageStatus.of(
                        MessageWrapper.Status.SUCCESS,
                        "No emails found"
                );
            }

            log.info("Emails fetched: {}", emailList);

            // 🔹 Step 6: Convert to array
            String[] emailIds = emailList.toArray(new String[0]);

            // 🔹 Step 7: Send email
            OmsFormatter omsFormatter = new OmsFormatter();

            omsFormatter.omsEmailXML(
                    emailIds,
                    String.valueOf(recId),
                    Constants.AppEvents.EVT_TTI_SEND_TO_BANK_ALERT
            );

            log.info("Email sent successfully for recId: {}", recId);

            // 🔹 Step 8: Success
            return MessageStatus.of(
                    MessageWrapper.Status.SUCCESS,
                    "SendToBank Alert Successful"
            );

        } catch (Exception e) {

            log.error("SendToBankAlertProcessor Failed", e);

            return MessageStatus.of(
                    MessageWrapper.Status.FAILED,
                    "SendToBank Alert Failed: " + e.getMessage()
            );
        }
    }

