package com.sc.cib.trade.listener;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.sc.cib.trade.model.request.PostAceMsgRqst;
import org.springframework.jms.annotation.JmsListener;
import org.springframework.stereotype.Component;

@Component
public class AceMessageListener {

    private final ObjectMapper mapper = new ObjectMapper();

    @JmsListener(destination = "ACE.QUEUE.NAME")
    public void receiveMessage(String message) {
        try {
            System.out.println("----- MESSAGE RECEIVED -----");
            System.out.println("Raw Message: " + message);

            PostAceMsgRqst req =
                    mapper.readValue(message, PostAceMsgRqst.class);

            System.out.println("ProcessId: " + req.getProcessId());
            System.out.println("AceRequest: " + req.getAceRequest());

            // TODO: Add DB update or service call here

            System.out.println("----- MESSAGE PROCESSED -----");

        } catch (Exception e) {
            System.err.println("Error reading message");
            e.printStackTrace();
        }
    }
}
