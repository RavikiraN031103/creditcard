:root {
  --primary-color: #7a4f3e;
  --accent-color: #ffa726;
  --secondary-color: #88024f;
  --admin-color: #4b145e;
}

/* Overlay */
.modal-overlay {
  position: fixed;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease-in-out;
}

/* Modal Card */
.modal-card {
  background-color: #fff;
  width: 400px;
  padding: 2.2rem;
  border-radius: 14px;
  box-shadow: 0px 8px 20px rgba(0, 0, 0, 0.25);
  text-align: center;
  position: relative;
  animation: popup 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes popup {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

/* Close Button */
.close-btn {
  position: absolute;
  top: 10px;
  right: 14px;
  background: none;
  border: none;
  font-size: 1.5rem;
  color: var(--secondary-color);
  cursor: pointer;
  transition: color 0.3s;
}
.close-btn:hover {
  color: var(--accent-color);
}

/* Inputs */
.modal-card input,
.modal-card select {
  width: 100%;
  padding: 10px 12px;
  margin-bottom: 1rem;
  border: 1px solid #ccc;
  border-radius: 6px;
  font-size: 1rem;
  outline: none;
  transition: border-color 0.3s;
}
.modal-card input:focus,
.modal-card select:focus {
  border-color: var(--accent-color);
}

/* Submit Button */
.modal-card button {
  width: 100%;
  padding: 12px;
  border-radius: 6px;
  color: white;
  font-size: 1rem;
  border: none;
  cursor: pointer;
  transition: background-color 0.3s;
}

/* Themed Buttons */
.modal-user button {
  background-color: var(--primary-color);
}
.modal-user button:hover {
  background-color: var(--accent-color);
}

.modal-admin button {
  background-color: var(--admin-color);
}
.modal-admin button:hover {
  background-color: var(--accent-color);
}

/* Error box */
.error-box {
  color: var(--secondary-color);
  background-color: rgba(255, 0, 0, 0.05);
  border-left: 3px solid var(--secondary-color);
  padding: 8px 10px;
  margin-bottom: 1rem;
  border-radius: 4px;
  font-size: 0.9rem;
}
