import React, { useState } from "react";
import axios from "axios";
import { useAuth } from "../AuthContext";
import { useNavigate } from "react-router-dom";
import "../styles/Login.css";
import "../styles/Modal.css";

const Login = () => {
  const { login } = useAuth();
  const navigate = useNavigate();

  // State management
  const [modalType, setModalType] = useState(""); // "userLogin", "adminLogin", "userSignup", "adminSignup"
  const [error, setError] = useState("");

  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [userName, setUserName] = useState("");
  const [role, setRole] = useState("User");
  const [phoneNumber, setPhoneNumber] = useState("");
  const [location, setLocation] = useState("");

  // Login & Signup handlers
  const handleLogin = async (endpoint) => {
    try {
      const response = await axios.post(endpoint, { email, password });
      const { token, role, userId } = response.data;

      localStorage.setItem("authToken", token);
      localStorage.setItem("role", role);
      localStorage.setItem("userId", userId);

      login(token, role, userId);
      alert("Login successful!");
      setModalType("");
      navigate("/dashboard");
    } catch {
      setError("Login failed. Check your credentials.");
    }
  };

  const handleSignup = async (endpoint) => {
    try {
      const dataToSend = {
        userName,
        email,
        password,
        role,
        phoneNumber: parseInt(phoneNumber, 10),
        location,
      };
      await axios.post(endpoint, dataToSend);
      alert("Signup successful! Please login.");
      setModalType("");
    } catch {
      setError("Signup failed. Please try again.");
    }
  };

  return (
    <div className="login-landing">
      <div className="welcome-box">
        <h1>
          Welcome to <span>SIMBA Events</span>
        </h1>
        <p>
          Explore, manage, and create unforgettable experiences with our event platform.
        </p>

        <div className="landing-buttons">
          <button className="btn btn-user" onClick={() => setModalType("userLogin")}>
            User Login
          </button>
          <button className="btn btn-admin" onClick={() => setModalType("adminLogin")}>
            Admin Login
          </button>
          <button className="btn btn-user" onClick={() => setModalType("userSignup")}>
            User Signup
          </button>
          <button className="btn btn-admin" onClick={() => setModalType("adminSignup")}>
            Admin Signup
          </button>
        </div>
      </div>

      {/* MODALS */}
      {modalType.includes("Login") && (
        <div className="modal-overlay">
          <div
            className={`modal-card ${
              modalType.startsWith("user") ? "modal-user" : "modal-admin"
            }`}
          >
            <div className="modal-header"></div>
            <button className="close-btn" onClick={() => setModalType("")}>
              ×
            </button>
            <h2>{modalType.startsWith("user") ? "User Login" : "Admin Login"}</h2>
            {error && <div className="error-box">{error}</div>}

            <form
              onSubmit={(e) => {
                e.preventDefault();
                handleLogin(
                  modalType.startsWith("user")
                    ? "https://localhost:7283/api/Users/login"
                    : "https://localhost:7283/api/Admin/login"
                );
              }}
            >
              <input
                type="email"
                placeholder="Email address"
                value={email}
                onChange={(e) => setEmail(e.target.value)}
                required
              />
              <input
                type="password"
                placeholder="Password"
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                required
              />
              <button type="submit">Login</button>
            </form>
          </div>
        </div>
      )}

      {modalType.includes("Signup") && (
        <div className="modal-overlay">
          <div
            className={`modal-card ${
              modalType.startsWith("user") ? "modal-user" : "modal-admin"
            }`}
          >
            <div className="modal-header"></div>
            <button className="close-btn" onClick={() => setModalType("")}>
              ×
            </button>
            <h2>{modalType.startsWith("user") ? "User Signup" : "Admin Signup"}</h2>
            {error && <div className="error-box">{error}</div>}

            <form
              onSubmit={(e) => {
                e.preventDefault();
                handleSignup(
                  modalType.startsWith("user")
                    ? "https://localhost:7283/api/Users/register"
                    : "https://localhost:7283/api/Admin/register"
                );
              }}
            >
              <input
                type="text"
                placeholder="Full Name"
                value={userName}
                onChange={(e) => setUserName(e.target.value)}
                required
              />
              <input
                type="email"
                placeholder="Email address"
                value={email}
                onChange={(e) => setEmail(e.target.value)}
                required
              />
              <input
                type="password"
                placeholder="Password"
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                required
              />
              <input
                type="tel"
                placeholder="Phone Number"
                value={phoneNumber}
                onChange={(e) => setPhoneNumber(e.target.value)}
                required
              />
              <input
                type="text"
                placeholder="Location"
                value={location}
                onChange={(e) => setLocation(e.target.value)}
                required
              />
              <button type="submit">Signup</button>
            </form>
          </div>
        </div>
      )}
    </div>
  );
};

export default Login;
