:root {
  --primary-color: #7a4f3e;
  --accent-color: #ffa726;
  --secondary-color: #88024f;
  --admin-color: #4b145e;
}

/* Overlay */
.modal-overlay {
  position: fixed;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.4s ease-in-out;
}

/* Modal Card */
.modal-card {
  background-color: #ffffff;
  width: 400px;
  padding: 2.4rem;
  border-radius: 16px;
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
  text-align: center;
  position: relative;
  transform: translateY(-10px);
  animation: slideUp 0.4s ease forwards;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Modal Header Bar */
.modal-header {
  height: 5px;
  border-radius: 4px;
  margin-bottom: 1.2rem;
}

.modal-user .modal-header {
  background: var(--primary-color);
}
.modal-admin .modal-header {
  background: var(--admin-color);
}

/* Close Button */
.close-btn {
  position: absolute;
  top: 10px;
  right: 15px;
  background: none;
  border: none;
  font-size: 1.5rem;
  color: var(--secondary-color);
  cursor: pointer;
  transition: color 0.3s ease;
}

.close-btn:hover {
  color: var(--accent-color);
}

/* Inputs */
.modal-card input,
.modal-card select {
  width: 100%;
  padding: 10px 12px;
  margin-bottom: 1rem;
  border: 1px solid #ccc;
  border-radius: 6px;
  font-size: 1rem;
  outline: none;
  transition: border-color 0.3s;
}

.modal-card input:focus,
.modal-card select:focus {
  border-color: var(--accent-color);
  box-shadow: 0 0 5px rgba(255, 167, 38, 0.5);
}

/* Submit Button */
.modal-card button {
  width: 100%;
  padding: 12px;
  border-radius: 6px;
  color: white;
  font-size: 1rem;
  border: none;
  cursor: pointer;
  transition: transform 0.3s, background-color 0.3s;
}

.modal-card button:hover {
  transform: scale(1.03);
}

/* Themed Buttons */
.modal-user button {
  background-color: var(--primary-color);
}
.modal-admin button {
  background-color: var(--admin-color);
}

.modal-user button:hover,
.modal-admin button:hover {
  background-color: var(--accent-color);
}

/* Error Box */
.error-box {
  color: var(--secondary-color);
  background-color: rgba(255, 0, 0, 0.05);
  border-left: 3px solid var(--secondary-color);
  padding: 8px 10px;
  margin-bottom: 1rem;
  border-radius: 4px;
  font-size: 0.9rem;
}

/* Responsive */
@media (max-width: 500px) {
  .modal-card {
    width: 90%;
    padding: 2rem 1.8rem;
  }
}
