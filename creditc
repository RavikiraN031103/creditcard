:root {
  --primary-color: #7a4f3e;
  --accent-color: #ffa726;
  --secondary-color: #88024f;
  --background-color: #f5f5bc;
  --text-color: #333333;
  --admin-color: #4b145e; /* purple tone for admin theme */
}

/* Landing Layout */
.login-landing {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: var(--background-color);
  text-align: center;
  font-family: "Poppins", sans-serif;
  padding: 20px;
}

.login-landing h1 {
  color: var(--primary-color);
  font-size: 2.4rem;
  margin-bottom: 0.5rem;
}

.login-landing h1 span {
  color: var(--accent-color);
}

.login-landing p {
  color: var(--text-color);
  font-size: 1.1rem;
  margin-bottom: 2.5rem;
}

/* Buttons Layout */
.landing-buttons {
  display: grid;
  grid-template-columns: repeat(2, minmax(150px, 1fr));
  gap: 1rem;
  width: 320px;
}

.btn {
  padding: 12px 24px;
  border-radius: 8px;
  font-size: 1rem;
  cursor: pointer;
  border: none;
  transition: all 0.3s ease;
  font-weight: 500;
}

/* User Buttons */
.btn-user {
  background-color: var(--primary-color);
  color: #fff;
}
.btn-user:hover {
  background-color: var(--accent-color);
}

/* Admin Buttons */
.btn-admin {
  background-color: var(--admin-color);
  color: #fff;
}
.btn-admin:hover {
  background-color: var(--accent-color);
}

@media (max-width: 480px) {
  .landing-buttons {
    grid-template-columns: 1fr;
    width: 90%;
  }
}
