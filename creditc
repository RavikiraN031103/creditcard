import React, { useState } from "react";
import axios from "axios";
import { useAuth } from "../AuthContext";
import { useNavigate } from "react-router-dom";
import "../styles/Login.css";
import "../styles/Modal.css";

const Login = () => {
  const { login } = useAuth();
  const navigate = useNavigate();

  // Modal states
  const [modalType, setModalType] = useState(""); // "login" or "signup"
  const [error, setError] = useState("");

  // Form data
  const [role, setRole] = useState("User");
  const [userName, setUserName] = useState("");
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [phoneNumber, setPhoneNumber] = useState("");
  const [location, setLocation] = useState("");

  // Login
  const handleLogin = async () => {
    try {
      const endpoint =
        role === "User"
          ? "https://localhost:7283/api/Users/login"
          : "https://localhost:7283/api/Admin/login";

      const response = await axios.post(endpoint, { email, password });
      const { token, role: userRole, userId } = response.data;

      localStorage.setItem("authToken", token);
      localStorage.setItem("role", userRole);
      localStorage.setItem("userId", userId);

      login(token, userRole, userId);
      alert("Login successful!");
      setModalType("");
      navigate("/dashboard");
    } catch {
      setError("Login failed. Check your credentials.");
    }
  };

  // Signup
  const handleSignup = async () => {
    try {
      const endpoint =
        role === "User"
          ? "https://localhost:7283/api/Users/register"
          : "https://localhost:7283/api/Admin/register";

      const dataToSend = {
        userName,
        email,
        password,
        role,
        phoneNumber: parseInt(phoneNumber, 10),
        location,
      };

      await axios.post(endpoint, dataToSend);
      alert("Signup successful! Please login.");
      setModalType("");
    } catch {
      setError("Signup failed. Please try again.");
    }
  };

  return (
    <div className="login-landing">
      <div className="welcome-box">
        <h1>
          Welcome to <span>SIMBA Events</span>
        </h1>
        <p>
          Manage, explore, and create amazing experiences with a single platform
          for users and organisers.
        </p>

        <div className="landing-buttons">
          <button className="btn btn-user" onClick={() => setModalType("login")}>
            Login
          </button>
          <button className="btn btn-admin" onClick={() => setModalType("signup")}>
            Signup
          </button>
        </div>
      </div>

      {/* LOGIN MODAL */}
      {modalType === "login" && (
        <div className="modal-overlay">
          <div className="modal-card">
            <button className="close-btn" onClick={() => setModalType("")}>
              ×
            </button>
            <h2>Login</h2>
            {error && <div className="error-box">{error}</div>}

            <form
              onSubmit={(e) => {
                e.preventDefault();
                handleLogin();
              }}
            >
              <select
                value={role}
                onChange={(e) => setRole(e.target.value)}
                required
              >
                <option value="User">User</option>
                <option value="Organiser">Organiser</option>
              </select>
              <input
                type="email"
                placeholder="Email address"
                value={email}
                onChange={(e) => setEmail(e.target.value)}
                required
              />
              <input
                type="password"
                placeholder="Password"
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                required
              />
              <button type="submit">Login</button>
            </form>
          </div>
        </div>
      )}

      {/* SIGNUP MODAL */}
      {modalType === "signup" && (
        <div className="modal-overlay">
          <div className="modal-card">
            <button className="close-btn" onClick={() => setModalType("")}>
              ×
            </button>
            <h2>Signup</h2>
            {error && <div className="error-box">{error}</div>}

            <form
              onSubmit={(e) => {
                e.preventDefault();
                handleSignup();
              }}
            >
              <select
                value={role}
                onChange={(e) => setRole(e.target.value)}
                required
              >
                <option value="User">User</option>
                <option value="Organiser">Organiser</option>
              </select>
              <input
                type="text"
                placeholder="Full Name"
                value={userName}
                onChange={(e) => setUserName(e.target.value)}
                required
              />
              <input
                type="email"
                placeholder="Email address"
                value={email}
                onChange={(e) => setEmail(e.target.value)}
                required
              />
              <input
                type="password"
                placeholder="Password"
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                required
              />
              <input
                type="tel"
                placeholder="Phone Number"
                value={phoneNumber}
                onChange={(e) => setPhoneNumber(e.target.value)}
                required
              />
              <select
                value={location}
                onChange={(e) => setLocation(e.target.value)}
                required
              >
                <option value="">-- Select Your City --</option>
                <option value="Amaravati">Amaravati (Andhra Pradesh)</option>
                <option value="Itanagar">Itanagar (Arunachal Pradesh)</option>
                <option value="Dispur">Dispur (Assam)</option>
                <option value="Patna">Patna (Bihar)</option>
                <option value="Raipur">Raipur (Chhattisgarh)</option>
                <option value="Panaji">Panaji (Goa)</option>
                <option value="Gandhinagar">Gandhinagar (Gujarat)</option>
                <option value="Shimla">Shimla (Himachal Pradesh)</option>
                <option value="Ranchi">Ranchi (Jharkhand)</option>
               
              </select>
              <button type="submit">Signup</button>
            </form>
          </div>
        </div>
      )}
    </div>
  );
};

export default Login;


