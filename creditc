:root {
  --primary-color: #7a4f3e;
  --accent-color: #ffa726;
  --secondary-color: #88024f;
  --admin-color: #4b145e;
  --background-gradient: linear-gradient(135deg, #f5f5bc 0%, #ffecc7 100%);
  --text-color: #333333;
}

/* Animated background gradient */
.login-landing {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: var(--background-gradient);
  font-family: "Poppins", sans-serif;
  color: var(--text-color);
  text-align: center;
  overflow: hidden;
  animation: fadeInPage 1s ease;
}

@keyframes fadeInPage {
  from {
    opacity: 0;
    transform: scale(1.05);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* SIMBA Title */
.login-landing h1 {
  font-size: 2.6rem;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 0.4rem;
  letter-spacing: 1px;
}

.login-landing h1 span {
  color: var(--accent-color);
}

.login-landing p {
  font-size: 1.1rem;
  margin-bottom: 3rem;
  opacity: 0.9;
  max-width: 550px;
}

/* Interactive Card Box */
.welcome-box {
  background: white;
  padding: 3rem 3.5rem;
  border-radius: 20px;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(10px);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.welcome-box:hover {
  transform: translateY(-8px);
  box-shadow: 0 16px 35px rgba(0, 0, 0, 0.2);
}

/* Buttons Layout */
.landing-buttons {
  display: grid;
  grid-template-columns: repeat(2, minmax(150px, 1fr));
  gap: 1.2rem;
  width: 100%;
  margin-top: 1rem;
}

/* Button Styles */
.btn {
  padding: 12px 25px;
  border: none;
  border-radius: 10px;
  font-size: 1rem;
  cursor: pointer;
  font-weight: 500;
  letter-spacing: 0.3px;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

/* Button Shine Animation */
.btn::after {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.4);
  transform: skewX(-20deg);
  transition: left 0.5s ease;
}

.btn:hover::after {
  left: 120%;
}

/* User buttons */
.btn-user {
  background: var(--primary-color);
  color: white;
}

.btn-user:hover {
  background: var(--accent-color);
  transform: scale(1.03);
}

/* Admin buttons */
.btn-admin {
  background: var(--admin-color);
  color: white;
}

.btn-admin:hover {
  background: var(--accent-color);
  transform: scale(1.03);
}

/* Responsive */
@media (max-width: 600px) {
  .welcome-box {
    width: 90%;
    padding: 2.2rem 2rem;
  }

  .landing-buttons {
    grid-template-columns: 1fr;
  }
}
